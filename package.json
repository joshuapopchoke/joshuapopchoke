{
  "name": "fiduciary-duty",
  "version": "1.0.0",
  "description": "A financial planning simulation trainer",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "npm run build:renderer && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build:renderer": "vite build",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "dev:renderer": "vite",
    "preview": "npm run build && electron .",
    "test": "npm run typecheck && npm run test:engines",
    "test:engines": "tsc -p tsconfig.test.json && node dist-tests/tools/engine-selfcheck.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "dist": "npm run build && electron-builder --publish never",
    "dist:publish": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "electron": "^28.3.3",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.fiduciaryduty.desktop",
    "productName": "Fiduciary Duty",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/electron/main.js"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage"]
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://example.invalid/fiduciary-duty-updates"
      }
    ]
  }
}
