{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "dist-tests",
    "rootDir": ".",
    "types": ["node"]
  },
  "include": [
    "src/types/**/*.ts",
    "src/data/**/*.ts",
    "src/engine/**/*.ts",
    "tools/**/*.ts",
    "tools/engine-selfcheck.ts",
    "tools/stress-sim.ts"
  ]
}
